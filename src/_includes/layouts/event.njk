---
layout: base.njk
---

{% if latitude and longitude and latitude != 0 and longitude != 0 %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css">
{% endif %}

<div class="container event-detail" data-event-slug="{{ slug }}"{% if sessionizeApiId %} data-sessionize-id="{{ sessionizeApiId }}"{% endif %}{% if attendeeCount %} data-attendee-count="{{ attendeeCount }}"{% endif %} data-event-date="{{ date }}" data-event-location="{{ location }}">
  <div class="breadcrumb-row">
    <a href="/events/">&larr; All Events</a>
    <span class="breadcrumb-divider">|</span>
    <a href="/chapters/{{ chapterSlug }}/">{{ chapterSlug | capitalize }} Chapter</a>
  </div>

  <header class="event-page-header">
    <div>
      <p class="page-kicker">Community event</p>
      <h1>{{ title }}</h1>
    </div>
    <div class="event-header-actions">
      <a href="/register/?event={{ slug }}" class="btn-cta" id="register-btn">Register Now</a>
      <button type="button" class="btn-share" id="share-btn" aria-label="Share this event" title="Share this event">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        <span class="btn-share-text">Share</span>
      </button>
    </div>
  </header>

  <div class="cards cards--info">
    <div class="card card--centered">
      <p class="icon-xl"><span class="icon icon--lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span></p>
      <span class="info-label">Date</span>
      <p class="text-semibold">{{ date | humanDate }}</p>
      <button type="button" class="btn-add-calendar" id="add-to-calendar" aria-label="Add to calendar" title="Add to calendar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
        Add to Calendar
      </button>
    </div>
    <div class="card card--centered">
      <p class="icon-xl"><span class="icon icon--lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span></p>
      <span class="info-label">Location</span>
      <p class="text-semibold location-short" id="location-card-text">{{ location | truncateLocation }}</p>
    </div>
    <div class="card card--centered">
      <p class="icon-xl"><span class="icon icon--lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg></span></p>
      <span class="info-label">Registration</span>
      <p class="text-semibold" id="reg-count"><span class="skeleton skeleton-inline" aria-label="Loading registration count"></span></p>
    </div>
  </div>

  <h2>About This Event</h2>
  <div id="event-description" class="event-description">{{ description | descriptionToHtml | safe }}</div>

  {% if sessionizeApiId %}
  <section class="event-programme" aria-label="Programme">
    <h2>Agenda</h2>
    <div id="sessionize-agenda">
      <div class="skeleton skeleton-text" style="width:80%"></div>
      <div class="skeleton skeleton-text" style="width:60%"></div>
      <div class="skeleton skeleton-text" style="width:70%"></div>
    </div>

    <h2>Speakers</h2>
    <div id="sessionize-speakers">
      <div class="skeleton-grid">
        <div class="skeleton skeleton-card"></div>
        <div class="skeleton skeleton-card"></div>
        <div class="skeleton skeleton-card"></div>
      </div>
    </div>
  </section>
  {% endif %}

  <section id="volunteer-cards" class="recognition-section is-hidden" aria-labelledby="recognition-heading">
    <p class="section-kicker">Community recognition</p>
    <h2 id="recognition-heading">Event Team</h2>
    <p class="recognition-intro">Thank you to the people helping make this event possible.</p>
    <div id="recognition-groups" class="recognition-groups"></div>
  </section>

  <div id="community-partners" class="partners-section is-hidden">
    <h2>Community Partners</h2>
    <div id="partners-content"></div>
  </div>

  <h2>Location</h2>
  <p><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span> <span id="location-full-text">{{ location }}</span></p>
  {% if latitude and longitude and latitude != 0 and longitude != 0 %}
  <div id="event-map" class="event-map" data-lat="{{ latitude }}" data-lng="{{ longitude }}" data-name="{{ title }}" aria-label="Map showing the event location"></div>
  {% endif %}
</div>

<script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.5/dist/purify.min.js" integrity="sha384-qSFej5dZNviyoPgYJ5+Xk4bEbX8AYddxAHPuzs1aSgRiXxJ3qmyWNaPsRkpv/+x5" crossorigin="anonymous"></script>
<script src="/js/event-page.js?v={{ cacheBust }}"></script>
{% if latitude and longitude and latitude != 0 and longitude != 0 %}
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js"></script>
<script src="/js/event-map.js?v={{ cacheBust }}"></script>
{% endif %}
