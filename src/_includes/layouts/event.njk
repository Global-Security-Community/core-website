---
layout: base.njk
---

<div class="container" data-event-slug="{{ slug }}"{% if sessionizeApiId %} data-sessionize-id="{{ sessionizeApiId }}"{% endif %}{% if attendeeCount %} data-attendee-count="{{ attendeeCount }}"{% endif %}>
  <div class="breadcrumb-row">
    <a href="/events/">&larr; All Events</a>
    <span class="breadcrumb-divider">|</span>
    <a href="/chapters/{{ chapterSlug }}/">{{ chapterSlug | capitalize }} Chapter</a>
  </div>

  <h1>{{ title }}</h1>

  <div class="cards cards--info">
    <div class="card card--centered">
      <p class="icon-xl">📅</p>
      <p class="text-semibold">{{ date }}{% if endDate %} – {{ endDate }}{% endif %}</p>
    </div>
    <div class="card card--centered">
      <p class="icon-xl">📍</p>
      <p class="text-semibold">{{ location }}</p>
    </div>
    <div class="card card--centered">
      <p class="icon-xl">🎟️</p>
      <p class="text-semibold" id="reg-count">Loading...</p>
    </div>
  </div>

  <div class="mb-section">
    <a href="/register/?event={{ slug }}" class="btn-cta" id="register-btn">Register Now</a>
  </div>

  <h2>About This Event</h2>
  <p>{{ description }}</p>

  <div id="volunteer-cards" class="volunteer-cards is-hidden">
    <h3>Event Volunteers</h3>
  </div>

  {% if sessionizeApiId %}
  <h2>Agenda</h2>
  <div id="sessionize-agenda"><p>Loading agenda...</p></div>

  <h2>Speakers</h2>
  <div id="sessionize-speakers"><p>Loading speakers...</p></div>
  {% endif %}

  <div id="community-partners" class="partners-section is-hidden">
    <h2>Community Partners</h2>
    <div id="partners-content"></div>
  </div>

  <h2>Location</h2>
  <p>📍 {{ location }}</p>
</div>

<script src="/js/event-page.js?v={{ cacheBust }}"></script>
